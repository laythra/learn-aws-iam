{
  "$id": "aws-iam-resource-policy-schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IAM Resource-Based Policy",
  "type": "object",
  "required": [
    "Statement"
  ],
  "additionalProperties": false,
  "properties": {
    "Version": {
      "type": "string",
      "enum": [
        "2012-10-17"
      ]
    },
    "Id": {
      "type": "string"
    },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "items": {
        "allOf": [
          {
            "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Statement"
          },
          {
            "type": "object",
            "required": [
              "Principal"
            ]
          }
        ]
      }
    }
  }
}
