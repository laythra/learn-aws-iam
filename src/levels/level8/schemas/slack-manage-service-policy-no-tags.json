{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "properties": {
    "Version": {
      "type": "string",
      "enum": [
        "2012-10-17"
      ]
    },
    "Statement": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "oneOf": [
          { "$ref": "#/definitions/secretsManagerStatement" },
          { "$ref": "#/definitions/codeDeployApplicationStatement" },
          { "$ref": "#/definitions/codeDeployDeploymentGroupStatement" },
          { "$ref": "#/definitions/codeDeployDeploymentConfigStatement" }
        ]
      },
      "allOf": [
        { "contains": { "$ref": "#/definitions/secretsManagerStatement" } },
        { "contains": { "$ref": "#/definitions/codeDeployApplicationStatement" } },
        { "contains": { "$ref": "#/definitions/codeDeployDeploymentGroupStatement" } },
        { "contains": { "$ref": "#/definitions/codeDeployDeploymentConfigStatement" } }
      ]
    }
  },
  "definitions": {
    "principalArnValue": {
      "type": "object",
      "required": ["aws:PrincipalArn"],
      "properties": {
        "aws:PrincipalArn": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": [
              "arn:aws:iam::123456789012:user/senior-sam",
              "arn:aws:iam::123456789012:user/senior-jordan"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "secretsManagerStatement": {
      "type": "object",
      "required": ["Effect", "Action", "Resource", "Condition"],
      "properties": {
        "Effect": { "const": "Allow" },
        "Action": {
          "oneOf": [
            { "const": "secretsmanager:GetSecretValue" },
            {
              "type": "array",
              "contains": { "const": "secretsmanager:GetSecretValue" }
            }
          ]
        },
        "Resource": {
          "const": "arn:aws:secretsmanager:us-east-1:123456789012:secret:slack-integration-secret"
        },
        "Condition": {
          "type": "object",
          "oneOf": [
            {
              "required": ["StringEquals"],
              "properties": {
                "StringEquals": { "$ref": "#/definitions/principalArnValue" }
              },
              "additionalProperties": false
            },
            {
              "required": ["ArnEquals"],
              "properties": {
                "ArnEquals": { "$ref": "#/definitions/principalArnValue" }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "codeDeployApplicationStatement": {
      "type": "object",
      "required": ["Effect", "Action", "Resource"],
      "properties": {
        "Effect": { "const": "Allow" },
        "Action": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": [
              "codedeploy:RegisterApplicationRevision",
              "codedeploy:ListApplicationRevisions",
              "codedeploy:GetApplication"
            ]
          }
        },
        "Resource": {
          "const": "arn:aws:codedeploy:us-east-1:123456789012:application:slack-alerting-app"
        }
      },
      "additionalProperties": false
    },
    "codeDeployDeploymentGroupStatement": {
      "type": "object",
      "required": ["Effect", "Action", "Resource"],
      "properties": {
        "Effect": { "const": "Allow" },
        "Action": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": [
              "codedeploy:CreateDeployment",
              "codedeploy:GetDeployment",
              "codedeploy:ListDeployments",
              "codedeploy:GetDeploymentGroup",
              "codedeploy:GetDeploymentConfig"
            ]
          }
        },
        "Resource": {
          "const": "arn:aws:codedeploy:us-east-1:123456789012:deploymentgroup:slack-alerting-app/staging-group"
        }
      },
      "additionalProperties": false
    },
    "codeDeployDeploymentConfigStatement": {
      "type": "object",
      "required": ["Effect", "Action", "Resource"],
      "properties": {
        "Effect": { "const": "Allow" },
        "Action": {
          "oneOf": [
            { "const": "codedeploy:GetDeploymentConfig" },
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "items": { "const": "codedeploy:GetDeploymentConfig" }
            }
          ]
        },
        "Resource": {
          "const": "arn:aws:codedeploy:us-east-1:123456789012:deploymentconfig:CodeDeployDefault.AllAtOnce"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
