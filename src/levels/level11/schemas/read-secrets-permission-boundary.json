{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "properties": {
    "Version": {
      "const": "2012-10-17"
    },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": [
          "Effect",
          "Action",
          "Resource",
          "Condition"
        ],
        "properties": {
          "Sid": {
            "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
          },
          "Effect": {
            "const": "Allow"
          },
          "Action": {
            "type": "array",
            "uniqueItems": true,
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "string",
              "enum": [
                "secretsmanager:GetSecretValue",
                "secretsmanager:DescribeSecret"
              ]
            }
          },
          "Resource": {
            "oneOf": [
              {
                "const": "*"
              },
              {
                "type": "array",
                "items": {
                  "const": "*"
                },
                "minItems": 1,
                "maxItems": 1,
                "uniqueItems": true
              }
            ]
          },
          "Condition": {
            "type": "object",
            "required": [
              "StringEquals"
            ],
            "properties": {
              "StringEquals": {
                "type": "object",
                "required": [
                  "secretsmanager:ResourceTag/team"
                ],
                "properties": {
                  "secretsmanager:ResourceTag/team": {
                    "const": "${aws:PrincipalTag/team}"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
