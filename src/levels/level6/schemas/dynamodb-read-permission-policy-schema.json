{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "properties": {
    "Version": {
      "type": "string",
      "const": "2012-10-17"
    },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "Effect",
          "Action",
          "Resource"
        ],
        "properties": {
          "Sid": {
            "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
          },
          "Effect": {
            "type": "string",
            "const": "Allow"
          },
          "Action": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "dynamodb:GetItem",
                "dynamodb:Query",
                "dynamodb:Scan",
                "dynamodb:DescribeTable"
              ]
            },
            "minItems": 4,
            "maxItems": 4
          },
          "Resource": {
            "oneOf": [
              {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "maxItems": 1,
                "items": {
                  "type": "string",
                  "const": "arn:aws:dynamodb:us-east-1:123456789012:table/finance-reports"
                }
              },
              {
                "type": "string",
                "const": "arn:aws:dynamodb:us-east-1:123456789012:table/finance-reports"
              }
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
