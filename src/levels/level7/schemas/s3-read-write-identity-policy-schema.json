{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "properties": {
    "Version": {
      "type": "string",
      "enum": [
        "2012-10-17"
      ]
    },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": [
          "Effect",
          "Action",
          "Resource"
        ],
        "properties": {
          "Effect": {
            "type": "string",
            "const": "Allow"
          },
          "Action": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "s3:GetObject",
                "s3:PutObject"
              ]
            },
            "minItems": 2,
            "maxItems": 2
          },
          "Resource": {
            "oneOf": [
              {
                "type": "string",
                "const": "arn:aws:s3:::incident-response-artifacts/*"
              },
              {
                "type": "array",
                "items": {
                  "type": "string",
                  "const": "arn:aws:s3:::incident-response-artifacts/*"
                },
                "minItems": 1,
                "maxItems": 1
              }
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
