{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "properties": {
    "Version": {
      "type": "string",
      "enum": [
        "2012-10-17"
      ]
    },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": [
          "Effect",
          "Action",
          "Resource",
          "Principal"
        ],
        "properties": {
          "Sid": {
            "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
          },
          "Effect": {
            "type": "string",
            "const": "Allow"
          },
          "Action": {
            "oneOf": [
              {
                "type": "string",
                "const": "s3:GetObject"
              },
              {
                "type": "array",
                "items": {
                  "type": "string",
                  "const": "s3:GetObject"
                },
                "minItems": 1,
                "maxItems": 1,
                "uniqueItems": true
              }
            ]
          },
          "Resource": {
            "oneOf": [
              {
                "type": "string",
                "const": "arn:aws:s3:::compliance-audit-trail/*"
              },
              {
                "type": "array",
                "items": {
                  "type": "string",
                  "const": "arn:aws:s3:::compliance-audit-trail/*"
                },
                "minItems": 1,
                "maxItems": 1
              }
            ]
          },
          "Principal": {
            "type": "object",
            "required": [
              "AWS"
            ],
            "additionalProperties": false,
            "properties": {
              "AWS": {
                "type": "string",
                "enum": [
                  "arn:aws:iam::123456789012:user/alex"
                ]
              }
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
