{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "properties": {
    "Version": {
      "type": "string",
      "const": "2012-10-17"
    },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": [
          "Effect",
          "Action",
          "Resource"
        ],
        "properties": {
          "Sid": {
            "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
          },
          "Effect": {
            "type": "string",
            "const": "Allow"
          },
          "Action": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "cloudfront:GetDistribution",
                "cloudfront:GetDistributionConfig"
              ]
            },
            "minItems": 2,
            "maxItems": 2,
            "uniqueItems": true
          },
          "Resource": {
            "oneOf": [
              {
                "type": "string",
                "const": "arn:aws:cloudfront::123456789012:distribution/E1A2B3C4D5E6F7"
              },
              {
                "type": "array",
                "items": {
                  "type": "string",
                  "const": "arn:aws:cloudfront::123456789012:distribution/E1A2B3C4D5E6F7"
                },
                "minItems": 1,
                "maxItems": 1,
                "uniqueItems": true
              }
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
