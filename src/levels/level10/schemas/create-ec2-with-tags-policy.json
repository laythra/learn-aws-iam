{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["Version", "Statement"],
  "additionalProperties": false,
  "properties": {
    "Version": { "const": "2012-10-17" },
    "Statement": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "oneOf": [
          { "$ref": "#/definitions/createTagsStatement" },
          { "$ref": "#/definitions/runInstancesStatement" },
          { "$ref": "#/definitions/runInstancesSupportingResourcesStatement" }
        ]
      },
      "allOf": [
        { "contains": { "$ref": "#/definitions/createTagsStatement" } },
        { "contains": { "$ref": "#/definitions/runInstancesStatement" } },
        { "contains": { "$ref": "#/definitions/runInstancesSupportingResourcesStatement" } }
      ]
    }
  },
  "definitions": {
    "createTagsCondition": {
      "type": "object",
      "required": ["StringEquals"],
      "additionalProperties": false,
      "properties": {
        "StringEquals": {
          "type": "object",
          "required": ["ec2:CreateAction"],
          "additionalProperties": false,
          "properties": {
            "ec2:CreateAction": { "const": "RunInstances" }
          }
        }
      }
    },
    "runInstancesCondition": {
      "type": "object",
      "required": ["StringEquals", "ForAllValues:StringEquals"],
      "additionalProperties": false,
      "properties": {
        "StringEquals": {
          "type": "object",
          "required": ["aws:RequestTag/application", "aws:RequestTag/environment"],
          "additionalProperties": false,
          "properties": {
            "aws:RequestTag/application": { "const": "${aws:PrincipalTag/application}" },
            "aws:RequestTag/environment": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "uniqueItems": true,
              "items": { "enum": ["dev", "staging", "prod"] }
            }
          }
        },
        "ForAllValues:StringEquals": {
          "type": "object",
          "required": ["aws:TagKeys"],
          "additionalProperties": false,
          "properties": {
            "aws:TagKeys": {
              "type": "array",
              "minItems": 2,
              "maxItems": 3,
              "uniqueItems": true,
              "items": { "enum": ["application", "environment", "Name"] }
            }
          }
        }
      }
    },
    "createTagsStatement": {
      "type": "object",
      "required": ["Effect", "Action", "Resource", "Condition"],
      "additionalProperties": false,
      "properties": {
        "Sid": {
          "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
        },
        "Effect": { "const": "Allow" },
        "Action": {
          "oneOf": [
            { "const": "ec2:CreateTags" },
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "items": { "const": "ec2:CreateTags" }
            }
          ]
        },
        "Resource": { "const": "*" },
        "Condition": { "$ref": "#/definitions/createTagsCondition" }
      }
    },
    "runInstancesStatement": {
      "type": "object",
      "required": ["Effect", "Action", "Resource", "Condition"],
      "additionalProperties": false,
      "properties": {
        "Sid": {
          "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
        },
        "Effect": { "const": "Allow" },
        "Action": {
          "oneOf": [
            { "const": "ec2:RunInstances" },
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "items": { "const": "ec2:RunInstances" }
            }
          ]
        },
        "Resource": {
          "oneOf": [
            { "const": "arn:aws:ec2:*:*:instance/*" },
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "items": { "const": "arn:aws:ec2:*:*:instance/*" }
            }
          ]
        },
        "Condition": { "$ref": "#/definitions/runInstancesCondition" }
      }
    },
    "runInstancesSupportingResourcesStatement": {
      "type": "object",
      "required": ["Effect", "Action", "Resource"],
      "additionalProperties": false,
      "properties": {
        "Sid": {
          "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
        },
        "Effect": { "const": "Allow" },
        "Action": {
          "oneOf": [
            { "const": "ec2:RunInstances" },
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "items": { "const": "ec2:RunInstances" }
            }
          ]
        },
        "Resource": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": [
              "arn:aws:ec2:*:*:subnet/*",
              "arn:aws:ec2:*:*:network-interface/*",
              "arn:aws:ec2:*:*:security-group/*",
              "arn:aws:ec2:*:*:volume/*",
              "arn:aws:ec2:*::image/*"
            ]
          }
        }
      }
    }
  }
}
