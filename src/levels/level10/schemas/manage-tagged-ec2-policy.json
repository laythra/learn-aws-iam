{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["Version", "Statement"],
  "additionalProperties": false,
  "properties": {
    "Version": { "const": "2012-10-17" },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": ["Effect", "Action", "Resource", "Condition"],
        "additionalProperties": false,
        "properties": {
          "Sid": {
            "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
          },
          "Effect": { "const": "Allow" },
          "Action": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": ["ec2:StartInstances", "ec2:StopInstances"]
            }
          },
          "Resource": {
            "oneOf": [
              { "const": "*" },
              {
                "type": "array",
                "minItems": 1,
                "maxItems": 1,
                "uniqueItems": true,
                "items": { "const": "*" }
              }
            ]
          },
          "Condition": {
            "type": "object",
            "required": ["StringEquals"],
            "additionalProperties": false,
            "properties": {
              "StringEquals": {
                "type": "object",
                "required": ["aws:ResourceTag/application"],
                "additionalProperties": false,
                "properties": {
                  "aws:ResourceTag/application": {
                    "const": "${aws:PrincipalTag/application}"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
