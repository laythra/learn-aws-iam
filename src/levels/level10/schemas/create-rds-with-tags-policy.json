{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "additionalProperties": false,
  "properties": {
    "Version": {
      "const": "2012-10-17"
    },
    "Statement": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": [
        {
          "$ref": "#/definitions/createTagsStatement"
        },
        {
          "$ref": "#/definitions/createRDSStatement"
        }
      ]
    }
  },
  "definitions": {
    "createTagsCondition": {
      "type": "object",
      "required": [
        "StringEquals"
      ],
      "additionalProperties": false,
      "properties": {
        "StringEquals": {
          "type": "object",
          "required": [
            "rds:CreateAction"
          ],
          "additionalProperties": false,
          "properties": {
            "rds:CreateAction": {
              "const": "CreateDBInstance"
            }
          }
        }
      }
    },
    "createRDSCondition": {
      "type": "object",
      "required": [
        "StringEquals",
        "ForAllValues:StringEquals"
      ],
      "additionalProperties": false,
      "properties": {
        "StringEquals": {
          "type": "object",
          "required": [
            "aws:RequestTag/team",
            "aws:RequestTag/environment"
          ],
          "additionalProperties": false,
          "properties": {
            "aws:RequestTag/team": {
              "const": "${aws:PrincipalTag/team}"
            },
            "aws:RequestTag/environment": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "dev",
                  "staging",
                  "prod"
                ]
              }
            }
          }
        },
        "ForAllValues:StringEquals": {
          "type": "object",
          "required": [
            "aws:TagKeys"
          ],
          "additionalProperties": false,
          "properties": {
            "aws:TagKeys": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "team",
                  "environment",
                  "name"
                ]
              }
            }
          }
        }
      }
    },
    "createTagsStatement": {
      "type": "object",
      "required": [
        "Effect",
        "Action",
        "Resource",
        "Condition"
      ],
      "additionalProperties": false,
      "properties": {
        "Sid": {
          "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
        },
        "Effect": {
          "const": "Allow"
        },
        "Action": {
          "oneOf": [
            {
              "const": "rds:AddTagsToResource"
            },
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "items": {
                "const": "rds:AddTagsToResource"
              }
            }
          ]
        },
        "Resource": {
          "const": "*"
        },
        "Condition": {
          "$ref": "#/definitions/createTagsCondition"
        }
      }
    },
    "createRDSStatement": {
      "type": "object",
      "required": [
        "Effect",
        "Action",
        "Resource",
        "Condition"
      ],
      "additionalProperties": false,
      "properties": {
        "Sid": {
          "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
        },
        "Effect": {
          "const": "Allow"
        },
        "Action": {
          "oneOf": [
            {
              "const": "rds:CreateDBInstance"
            },
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "items": {
                "const": "rds:CreateDBInstance"
              }
            }
          ]
        },
        "Resource": {
          "const": "*"
        },
        "Condition": {
          "$ref": "#/definitions/createRDSCondition"
        }
      }
    }
  }
}
