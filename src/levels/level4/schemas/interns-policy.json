{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "Version": {
      "type": "string",
      "const": "2012-10-17"
    },
    "Statement": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "oneOf": [
          {
            "$ref": "#/definitions/getObjectStmt"
          },
          {
            "$ref": "#/definitions/listBucketStmt"
          }
        ]
      },
      "allOf": [
        {
          "contains": {
            "$ref": "#/definitions/getObjectStmt"
          }
        },
        {
          "contains": {
            "$ref": "#/definitions/listBucketStmt"
          }
        }
      ]
    }
  },
  "required": [
    "Version",
    "Statement"
  ],
  "additionalProperties": false,
  "definitions": {
    "getObjectStmt": {
      "type": "object",
      "properties": {
        "Effect": {
          "type": "string",
          "const": "Allow"
        },
        "Action": {
          "oneOf": [
            {
              "type": "string",
              "const": "s3:GetObject"
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "const": "s3:GetObject"
              },
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true
            }
          ]
        },
        "Resource": {
          "oneOf": [
            {
              "type": "string",
              "const": "arn:aws:s3:::timeshift-assets/*"
            },
            {
              "type": "array",
              "items": {
                "const": "arn:aws:s3:::timeshift-assets/*"
              },
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true
            }
          ]
        }
      },
      "required": [
        "Effect",
        "Action",
        "Resource"
      ],
      "additionalProperties": false
    },
    "listBucketStmt": {
      "type": "object",
      "properties": {
        "Effect": {
          "type": "string",
          "const": "Allow"
        },
        "Action": {
          "oneOf": [
            {
              "type": "string",
              "const": "s3:ListBucket"
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "const": "s3:ListBucket"
              },
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true
            }
          ]
        },
        "Resource": {
          "oneOf": [
            {
              "type": "string",
              "const": "arn:aws:s3:::timeshift-assets"
            },
            {
              "type": "array",
              "items": {
                "const": "arn:aws:s3:::timeshift-assets"
              },
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true
            }
          ]
        }
      },
      "required": [
        "Effect",
        "Action",
        "Resource"
      ],
      "additionalProperties": false
    }
  }
}
