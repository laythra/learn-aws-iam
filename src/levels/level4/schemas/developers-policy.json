{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "Version": {
      "type": "string",
      "const": "2012-10-17"
    },
    "Statement": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "oneOf": [
          {
            "$ref": "#/definitions/dynamoStatement"
          },
          {
            "$ref": "#/definitions/s3Statement"
          }
        ]
      },
      "allOf": [
        {
          "contains": {
            "$ref": "#/definitions/dynamoStatement"
          }
        },
        {
          "contains": {
            "$ref": "#/definitions/s3Statement"
          }
        }
      ]
    }
  },
  "required": [
    "Version",
    "Statement"
  ],
  "additionalProperties": false,
  "definitions": {
    "dynamoStatement": {
      "type": "object",
      "properties": {
        "Effect": {
          "type": "string",
          "const": "Allow"
        },
        "Action": {
          "type": "array",
          "items": {
            "enum": [
              "dynamodb:GetItem",
              "dynamodb:PutItem",
              "dynamodb:UpdateItem",
              "dynamodb:Scan",
              "dynamodb:Query"
            ]
          },
          "uniqueItems": true,
          "minItems": 5,
          "maxItems": 5
        },
        "Resource": {
          "oneOf": [
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "arn:aws:dynamodb:us-east-1:123456789012:table/customer-data"
                ]
              }
            },
            {
              "type": "string",
              "const": "arn:aws:dynamodb:us-east-1:123456789012:table/customer-data"
            }
          ]
        }
      },
      "required": [
        "Effect",
        "Action",
        "Resource"
      ],
      "additionalProperties": false
    },
    "s3Statement": {
      "type": "object",
      "properties": {
        "Effect": {
          "type": "string",
          "const": "Allow"
        },
        "Action": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "s3:GetObject",
              "s3:PutObject"
            ]
          },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        },
        "Resource": {
          "oneOf": [
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "arn:aws:s3:::timeshift-assets/*"
                ]
              }
            },
            {
              "type": "string",
              "const": "arn:aws:s3:::timeshift-assets/*"
            }
          ]
        }
      },
      "required": [
        "Effect",
        "Action",
        "Resource"
      ],
      "additionalProperties": false
    }
  }
}
