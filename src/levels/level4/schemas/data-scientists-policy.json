{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "Version": {
      "type": "string",
      "const": "2012-10-17"
    },
    "Statement": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": [
        {
          "$ref": "#/definitions/dynamoStmt"
        },
        {
          "$ref": "#/definitions/s3Stmt"
        }
      ]
    }
  },
  "required": [
    "Version",
    "Statement"
  ],
  "additionalProperties": false,
  "definitions": {
    "dynamoStmt": {
      "type": "object",
      "properties": {
        "Sid": {
          "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
        },
        "Effect": {
          "type": "string",
          "const": "Allow"
        },
        "Action": {
          "type": "array",
          "items": {
            "enum": [
              "dynamodb:GetItem",
              "dynamodb:PutItem",
              "dynamodb:UpdateItem",
              "dynamodb:Scan",
              "dynamodb:Query"
            ]
          },
          "minItems": 5,
          "maxItems": 5,
          "uniqueItems": true
        },
        "Resource": {
          "type": "string",
          "const": "arn:aws:dynamodb:us-east-1:123456789012:table/analytics-data"
        }
      },
      "required": [
        "Effect",
        "Action",
        "Resource"
      ],
      "additionalProperties": false
    },
    "s3Stmt": {
      "type": "object",
      "properties": {
        "Sid": {
          "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
        },
        "Effect": {
          "type": "string",
          "const": "Allow"
        },
        "Action": {
          "type": "array",
          "items": {
            "enum": [
              "s3:GetObject",
              "s3:PutObject"
            ]
          },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        },
        "Resource": {
          "oneOf": [
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "items": {
                "const": "arn:aws:s3:::timeshift-assets/*"
              }
            },
            {
              "type": "string",
              "const": "arn:aws:s3:::timeshift-assets/*"
            }
          ]
        }
      },
      "required": [
        "Effect",
        "Action",
        "Resource"
      ],
      "additionalProperties": false
    }
  }
}
