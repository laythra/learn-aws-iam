{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "properties": {
    "Version": {
      "const": "2012-10-17"
    },
    "Statement": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "oneOf": [
          {
            "$ref": "#/definitions/secretsStatement"
          },
          {
            "$ref": "#/definitions/connectStatement"
          }
        ]
      },
      "allOf": [
        {
          "contains": {
            "$ref": "#/definitions/secretsStatement"
          }
        },
        {
          "contains": {
            "$ref": "#/definitions/connectStatement"
          }
        }
      ]
    }
  },
  "definitions": {
    "abacCondition": {
      "type": "object",
      "required": [
        "StringEquals"
      ],
      "properties": {
        "StringEquals": {
          "type": "object",
          "required": [
            "aws:ResourceTag/application"
          ],
          "properties": {
            "aws:ResourceTag/application": {
              "const": "${aws:PrincipalTag/application}"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "secretsStatement": {
      "type": "object",
      "required": [
        "Effect",
        "Action",
        "Resource",
        "Condition"
      ],
      "properties": {
        "Sid": {
          "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
        },
        "Effect": {
          "const": "Allow"
        },
        "Action": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["secretsmanager:GetSecretValue", "secretsmanager:DescribeSecret"]
          },
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true
        },
        "Resource": {
          "const": "arn:aws:secretsmanager:us-east-1:123456789012:secret:db/*"
        },
        "Condition": {
          "$ref": "#/definitions/abacCondition"
        }
      },
      "additionalProperties": false
    },
    "connectStatement": {
      "type": "object",
      "required": [
        "Effect",
        "Action",
        "Resource",
        "Condition"
      ],
      "properties": {
        "Sid": {
          "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
        },
        "Effect": {
          "const": "Allow"
        },
        "Action": {
          "oneOf": [
            {
              "type": "string",
              "const": "rds-db:connect"
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "const": "rds-db:connect"
              },
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true
            }
          ]
        },
        "Resource": {
          "const": "arn:aws:rds-db:us-east-1:123456789012:dbuser:*/*"
        },
        "Condition": {
          "$ref": "#/definitions/abacCondition"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
