{
  "$id": "s3-read-access-role-schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IAM Role Trust Policy",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "properties": {
    "Version": {
      "type": "string",
      "const": "2012-10-17"
    },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": [
          "Effect",
          "Principal",
          "Action"
        ],
        "additionalProperties": false,
        "properties": {
          "Sid": {
            "$ref": "aws-iam-shared-definitions-schema.json#/definitions/Sid"
          },
          "Effect": {
            "type": "string",
            "const": "Allow"
          },
          "Principal": {
            "type": "object",
            "required": [
              "AWS"
            ],
            "additionalProperties": false,
            "properties": {
              "AWS": {
                "type": "string",
                "const": "arn:aws:iam::123456789012:user/alex"
              }
            }
          },
          "Action": {
            "type": "string",
            "const": "sts:AssumeRole"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
