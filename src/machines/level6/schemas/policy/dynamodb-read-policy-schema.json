{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "properties": {
    "Version": {
      "type": "string",
      "enum": [
        "2012-10-17"
      ]
    },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "Effect",
          "Action",
          "Resource"
        ],
        "properties": {
          "Effect": {
            "type": "string",
            "const": "Allow"
          },
          "Action": {
            "type": "array",
            "uniqueItems": true,
            "contains": {
              "enum": [
                "dynamodb:GetItem",
                "dynamodb:Query",
                "dynamodb:Scan",
                "dynamodb:DescribeTable"
              ]
            },
            "minItems": 4
          },
          "Resource": {
            "type": "string",
            "const": "arn:aws:dynamodb:us-west-2:123456789012:table/finance-reports"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
