{
  "$id": "dynamodb-role-trust-policy-schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IAM Role Trust Policy",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "properties": {
    "Version": {
      "type": "string",
      "enum": [
        "2012-10-17"
      ],
      "description": "The version of the IAM policy language."
    },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": [
          "Effect",
          "Principal",
          "Action"
        ],
        "additionalProperties": false,
        "properties": {
          "Effect": {
            "type": "string",
            "const": "Allow"
          },
          "Principal": {
            "type": "object",
            "required": [
              "AWS"
            ],
            "additionalProperties": false,
            "properties": {
              "AWS": {
                "oneOf": [
                  {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 1,
                    "uniqueItems": true,
                    "items": {
                      "type": "string",
                      "enum": [
                        "arn:aws:iam::987654321098:user/omar"
                      ]
                    }
                  },
                  {
                    "type": "string",
                    "enum": [
                      "arn:aws:iam::987654321098:user/omar"
                    ]
                  }
                ]
              }
            }
          },
          "Action": {
            "anyOf": [
              {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "enum": [
                    "sts:AssumeRole"
                  ]
                },
                "minItems": 1,
                "maxItems": 1
              },
              {
                "type": "string",
                "const": "sts:AssumeRole"
              }
            ]
          }
        }
      }
    }
  }
}
