{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "properties": {
    "Version": {
      "type": "string",
      "enum": [
        "2012-10-17"
      ]
    },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "Effect",
          "Action",
          "Resource",
          "Condition"
        ],
        "properties": {
          "Effect": {
            "type": "string",
            "const": "Allow"
          },
          "Action": {
            "oneOf": [
              {
                "type": "array",
                "uniqueItems": true,
                "contains": {
                  "enum": [
                    "ec2:TerminateInstances"
                  ]
                },
                "minItems": 1
              },
              {
                "type": "string",
                "enum": [
                  "ec2:TerminateInstances"
                ]
              }
            ]
          },
          "Resource": {
            "type": "string",
            "const": "*"
          },
          "Condition": {
            "type": "object",
            "required": [
              "StringEquals"
            ],
            "properties": {
              "StringEquals": {
                "type": "object",
                "required": [
                  "ec2:ResourceTag/CreatedBy"
                ],
                "properties": {
                  "ec2:ResourceTag/CreatedBy": {
                    "type": "string",
                    "const": "${aws:username}"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
