{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "Version": {
      "type": "string",
      "const": "2012-10-17"
    },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": [
        {
          "required": [
            "Effect",
            "Action",
            "Resource",
            "Condition"
          ],
          "additionalProperties": false,
          "type": "object",
          "properties": {
            "Effect": {
              "type": "string",
              "const": "Allow"
            },
            "Action": {
              "oneOf": [
                {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "enum": [
                      "rds:AddTagsToResource"
                    ]
                  }
                },
                {
                  "type": "string",
                  "const": "rds:AddTagsToResource"
                }
              ]
            },
            "Resource": {
              "type": "string",
              "const": "*"
            },
            "Condition": {
              "type": "object",
              "required": [
                "StringEquals"
              ],
              "properties": {
                "StringEquals": {
                  "type": "object",
                  "required": [
                    "rds:CreateAction"
                  ],
                  "properties": {
                    "rds:CreateAction": {
                      "const": "CreateDBInstance"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  },
  "required": [
    "Version",
    "Statement"
  ],
  "additionalProperties": false
}
