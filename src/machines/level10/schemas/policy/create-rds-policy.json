{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "Version": {
      "type": "string",
      "const": "2012-10-17"
    },
    "Statement": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": [
        {
          "required": [
            "Effect",
            "Action",
            "Resource",
            "Condition"
          ],
          "additionalProperties": false,
          "type": "object",
          "properties": {
            "Effect": {
              "type": "string",
              "const": "Allow"
            },
            "Action": {
              "oneOf": [
                {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "enum": [
                      "rds:CreateDBInstance"
                    ]
                  }
                },
                {
                  "type": "string",
                  "const": "rds:CreateDBInstance"
                }
              ]
            },
            "Resource": {
              "type": "string",
              "const": "*"
            },
            "Condition": {
              "type": "object",
              "required": [
                "StringEquals",
                "ForAllValues:StringEquals"
              ],
              "properties": {
                "StringEquals": {
                  "type": "object",
                  "required": [
                    "aws:RequestTag/team",
                    "aws:RequestTag/cost-center",
                    "aws:RequestTag/environment",
                    "aws:RequestedRegion"
                  ],
                  "properties": {
                    "aws:RequestTag/team": {
                      "type": "string",
                      "const": "${aws:PrincipalTag/team}"
                    },
                    "aws:RequestTag/cost-center": {
                      "type": "string",
                      "const": "${aws:PrincipalTag/cost-center}"
                    },
                    "aws:RequestTag/environment": {
                      "type": "array",
                      "minItems": 3,
                      "maxItems": 3,
                      "uniqueItems": true,
                      "items": {
                        "enum": [
                          "dev",
                          "staging",
                          "prod"
                        ]
                      }
                    },
                    "aws:RequestedRegion": {
                      "type": "array",
                      "minItems": 3,
                      "maxItems": 3,
                      "uniqueItems": true,
                      "items": {
                        "enum": [
                          "us-east-1",
                          "us-west-2",
                          "eu-west-1"
                        ]
                      }
                    }
                  },
                  "additionalProperties": false
                },
                "ForAllValues:StringEquals": {
                  "type": "object",
                  "required": [
                    "aws:TagKeys"
                  ],
                  "properties": {
                    "aws:TagKeys": {
                      "type": "array",
                      "minItems": 3,
                      "maxItems": 3,
                      "uniqueItems": true,
                      "items": {
                        "enum": [
                          "team",
                          "environment",
                          "cost-center"
                        ]
                      }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          }
        }
      ]
    }
  },
  "required": [
    "Version",
    "Statement"
  ],
  "additionalProperties": false
}
