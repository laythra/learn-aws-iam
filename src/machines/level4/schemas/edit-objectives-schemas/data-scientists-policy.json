{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "Version": {
      "type": "string",
      "const": "2012-10-17"
    },
    "Statement": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "Effect": {
                "type": "string",
                "const": "Allow"
              },
              "Action": {
                "type": "array",
                "items": {
                  "enum": [
                    "dynamodb:GetItem",
                    "dynamodb:PutItem"
                  ]
                },
                "minItems": 2,
                "maxItems": 2,
                "uniqueItems": true
              },
              "Resource": {
                "type": "string",
                "const": "arn:aws:dynamodb:us-east-1:123456789012:table/analytics-data"
              }
            },
            "required": [
              "Effect",
              "Action",
              "Resource"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "Effect": {
                "type": "string",
                "const": "Allow"
              },
              "Action": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "s3:GetObject",
                    "s3:PutObject"
                  ]
                },
                "minItems": 2,
                "maxItems": 2,
                "uniqueItems": true
              },
              "Resource": {
                "oneOf": [
                  {
                    "type": "array",
                    "items": {
                      "enum": [
                        "arn:aws:s3:::timeshift-assets/*"
                      ]
                    },
                    "minItems": 1,
                    "maxItems": 1,
                    "uniqueItems": true
                  },
                  {
                    "type": "string",
                    "const": "arn:aws:s3:::timeshift-assets/*"
                  }
                ]
              }
            },
            "required": [
              "Effect",
              "Action",
              "Resource"
            ],
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "required": [
    "Version",
    "Statement"
  ],
  "additionalProperties": false
}
