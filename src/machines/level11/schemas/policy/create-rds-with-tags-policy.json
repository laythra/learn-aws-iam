{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "Version",
    "Statement"
  ],
  "properties": {
    "Version": {
      "type": "string",
      "enum": [
        "2012-10-17"
      ]
    },
    "Statement": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "oneOf": [
          {
            "$ref": "#/definitions/createTagsPolicy"
          },
          {
            "$ref": "#/definitions/createRDSPolicy"
          }
        ]
      }
    }
  },
  "definitions": {
    "createTagsPolicy": {
      "required": [
        "Effect",
        "Action",
        "Resource",
        "Condition"
      ],
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "Effect": {
          "type": "string",
          "const": "Allow"
        },
        "Action": {
          "oneOf": [
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "rds:AddTagsToResource"
                ]
              }
            },
            {
              "type": "string",
              "const": "rds:AddTagsToResource"
            }
          ]
        },
        "Resource": {
          "type": "string",
          "const": "*"
        },
        "Condition": {
          "type": "object",
          "required": [
            "StringEquals"
          ],
          "properties": {
            "StringEquals": {
              "type": "object",
              "required": [
                "rds:CreateAction"
              ],
              "properties": {
                "rds:CreateAction": {
                  "const": "CreateDBInstance"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    },
    "createRDSPolicy": {
      "required": [
        "Effect",
        "Action",
        "Resource",
        "Condition"
      ],
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "Effect": {
          "type": "string",
          "const": "Allow"
        },
        "Action": {
          "oneOf": [
            {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "rds:CreateDBInstance"
                ]
              }
            },
            {
              "type": "string",
              "const": "rds:CreateDBInstance"
            }
          ]
        },
        "Resource": {
          "type": "string",
          "const": "*"
        },
        "Condition": {
          "type": "object",
          "required": [
            "StringEquals",
            "ForAllValues:StringEquals"
          ],
          "properties": {
            "StringEquals": {
              "type": "object",
              "required": [
                "aws:RequestTag/team",
                "aws:RequestTag/environment"
              ],
              "properties": {
                "aws:RequestTag/team": {
                  "type": "string",
                  "const": "${aws:PrincipalTag/team}"
                },
                "aws:RequestTag/environment": {
                  "type": "array",
                  "minItems": 3,
                  "maxItems": 3,
                  "uniqueItems": true,
                  "items": {
                    "enum": [
                      "dev",
                      "staging",
                      "prod"
                    ]
                  }
                }
              },
              "additionalProperties": false
            },
            "ForAllValues:StringEquals": {
              "type": "object",
              "required": [
                "aws:TagKeys"
              ],
              "properties": {
                "aws:TagKeys": {
                  "type": "array",
                  "minItems": 3,
                  "maxItems": 3,
                  "uniqueItems": true,
                  "items": {
                    "enum": [
                      "team",
                      "environment",
                      "name"
                    ]
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    }
  },
  "additionalProperties": false
}
